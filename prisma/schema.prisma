generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  mongoId               String?   @unique // To keep track of old MongoDB ObjectId
  name                  String
  email                 String    @unique
  password              String
  role                  String    @default("admin")
  roleId                String?
  permissions           String[]
  status                String    @default("active")
  organizationId        String?
  companyName           String?
  phone                 String?
  industry              String?
  companySize           String?
  plan                  String    @default("trial")
  planExpiresAt         DateTime?
  isEmailVerified       Boolean   @default(false)
  department            String?
  position              String?
  employeeId            String?   @unique
  isActive              Boolean   @default(true)
  sessionToken          String?
  forgotPasswordToken   String?
  forgotPasswordExpires DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization          Organization? @relation(fields: [organizationId], references: [id])
  createdOrganizations  Organization[] @relation("OrganizationCreator")
  updatedOrganizations  Organization[] @relation("OrganizationUpdater")
  helpdeskTickets       HelpdeskTicket[] @relation("AssignedTickets")
}

model Organization {
  id                String    @id @default(uuid())
  mongoId           String?   @unique // To keep track of old MongoDB ObjectId
  orgId             String    @unique
  name              String
  description       String?
  email             String
  phone             String?
  street            String?
  status            String    @default("Active")
  website           String?
  memberCount       Int       @default(0)
  established       DateTime?
  logo              String?
  linkedinCompanyId String?
  createdById       String
  updatedById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  createdBy         User      @relation("OrganizationCreator", fields: [createdById], references: [id])
  updatedBy         User?     @relation("OrganizationUpdater", fields: [updatedById], references: [id])
  users             User[]
  employees         Employee[]
}

model Employee {
  id                    String    @id @default(uuid())
  mongoId               String?   @unique
  employeeId            String    @unique
  password              String?
  role                  String    @default("employee")
  roleId                String?
  isCompliant           Boolean   @default(false)
  isTDSApplicable       Boolean   @default(false)
  taxRegime             String    @default("new")

  firstName             String
  lastName              String
  email                 String    @unique
  phone                 String
  bloodGroup            String?
  dateOfJoining         DateTime
  dateOfBirth           DateTime?
  gender                String?

  department            String
  departmentId          String?
  employeeType          String?
  employeeTypeId        String?
  category              String?
  categoryId            String?
  organizationId        String?
  businessUnitId        String?
  teamId                String?
  costCenterId          String?
  designation           String
  reportingManager      String?
  teamLead              String?
  workLocation          String?
  assignedOfficeId      String?
  biometricDeviceId     String?
  defaultShift          String?
  workState             String    @default("Maharashtra")
  holidayListId         String?

  bankAccountNumber     String?
  bankName              String?
  ifscCode              String?
  branch                String?
  branchAddress         String?
  panNumber             String?
  aadharNumber          String?

  workingHr             Float?
  otApplicable          String    @default("no")
  esicApplicable        String    @default("no")
  pfApplicable          String    @default("no")
  pfType                String    @default("restricted")
  probation             String    @default("no")
  probationDuration     Int       @default(0)
  isAttending           String    @default("no")
  gratuityApplicable    String    @default("no")

  compOffBalance        Float     @default(0)
  status                String    @default("Active")
  
  createdById           String?
  updatedById           String?

  payslipStructure      Json?
  variablePayStructure  Json?
  attendanceApproval    Json?
  documents             Json?
  address               Json?
  temporaryAddress      Json?
  permanentAddress      Json?
  emergencyContact      Json?

  sessionToken          String?
  forgotPasswordToken   String?
  forgotPasswordExpires DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization          Organization? @relation(fields: [organizationId], references: [id])
  attendances           Attendance[]
  leaves                Leave[]
  helpdeskTickets       HelpdeskTicket[] @relation("EmployeeTickets")
}

model Attendance {
  id                  String    @id @default(uuid())
  mongoId             String?   @unique
  employeeId          String
  date                DateTime
  checkIn             DateTime?
  checkOut            DateTime?
  totalHours          Float     @default(0)
  status              String    @default("Present")
  isProxy             Boolean   @default(false)
  proxyDetails        Json?
  overtimeHours       Float     @default(0)
  dayType             String    @default("Full")
  workedHours         Float     @default(0)
  notes               String?
  location            Json?
  attendanceMethod    String    @default("Web")
  distanceFromOffice  Float?
  isGeofenceVerified  Boolean   @default(false)
  verificationFailureReason String?
  ipAddress           String?
  deviceId            String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee            Employee  @relation(fields: [employeeId], references: [id])
}

model Leave {
  id                  String    @id @default(uuid())
  mongoId             String?   @unique
  employeeId          String
  employeeCode        String
  employeeName        String
  organizationId      String?
  organizationType    String
  department          String
  month               Int
  year                Int

  leaves              Json?
  summary             Json?
  annualLeaveBalance  Json?
  
  status              String    @default("Draft")
  notes               String?

  createdById         String?
  updatedById         String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee            Employee  @relation(fields: [employeeId], references: [id])
}

model HelpdeskTicket {
  id                  String    @id @default(uuid())
  mongoId             String?   @unique
  employeeId          String
  subject             String
  category            String    @default("General")
  priority            String    @default("Medium")
  status              String    @default("Open")
  description         String
  comments            Json?
  assignedTo          String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee            Employee  @relation("EmployeeTickets", fields: [employeeId], references: [id])
  assignedUser        User?     @relation("AssignedTickets", fields: [assignedTo], references: [id])
}

